{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "IncomeEntry": {
      "title": "IncomeEntry",
      "description": "A single income transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "categoryId": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "amount", "categoryId", "date", "userId"]
    },
    "Category": {
      "title": "Category",
      "description": "User-defined income category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "color", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/entries/{entryId}": {
      "schema": "IncomeEntry",
      "description": "Income entries for a specific user"
    },
    "/users/{userId}/categories/{categoryId}": {
      "schema": "Category",
      "description": "Custom categories for a specific user"
    }
  }
}
